# ==========================================
#  Eshara Backend — Environment Variables
#  Copy this file to .env and fill in values
# ==========================================

# JWT secret key (use a long, random string in production)
JWT_SECRET=your_jwt_secret_key_here

# Port for the Node.js backend server
PORT=3000

# FastAPI model services URL (internal, not public)
MODEL_SERVICE_URL=http://localhost:8000

# Database URL (Prisma — for cloud PostgreSQL, replace with Neon connection string)
# For local development, Prisma will use the SQLite dev.db by default
DATABASE_URL="file:./dev.db"
