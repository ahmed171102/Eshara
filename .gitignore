# ==========================================
#   Eshara — Root .gitignore
# ==========================================

# --- Node.js ---
node_modules/
dist/
build/
.cache/
coverage/

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# --- Databases (NEVER commit real user data) ---
*.db
*.db-journal
*.sqlite
*.sqlite3

# --- Environment / Secrets ---
.env
.env.*
!.env.example

# --- Large ML artifacts (use download scripts or cloud storage) ---
*.npz
*.rar
arsl_graduation_sequences.npz
arsl_custom_subset.npz

# --- Large video datasets ---
*.mp4
*.avi
*.mov

# --- Jupyter autosaves ---
.ipynb_checkpoints/

# --- Derived Keras model copies ---
*.compat.h5

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- LaTeX build artifacts ---
*.aux
*.bbl
*.blg
*.lof
*.lot
*.toc
*.synctex.gz
*.synctex(busy)

# --- Temp ---
*.tmp
*.log
probe_results.tmp
